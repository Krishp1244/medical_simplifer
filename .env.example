# ─────────────────────────────────────────────────────────
# MediSimplify — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore so it will NOT be committed.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────

# Ollama API URL (default: local)
OLLAMA_URL=http://localhost:11434

# Default model to use for simplification
# Options: llama3.2, llama3.1, mistral, phi3, gemma2
DEFAULT_MODEL=llama3.2

# (Optional) If you ever add Google OAuth — add your client ID here
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# (Optional) If you ever add GitHub OAuth — add your client ID here
# GITHUB_CLIENT_ID=your-github-client-id
