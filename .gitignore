# ─────────────────────────────────────────────────────────
# MediSimplify — .gitignore
# ─────────────────────────────────────────────────────────

# ── Secrets & Environment ─────────────────────────────────
.env
*.env.local
*.env.production

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ── PDF output files ──────────────────────────────────────
*_simplified.txt

# ── OS files ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE & Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Node (if you ever add a build step) ──────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Logs ─────────────────────────────────────────────────
*.log
logs/
